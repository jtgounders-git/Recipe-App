<Window x:Class="Prog6221PoeRecipeAppP3.Views.SearchRecipe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Recipe" Height="200" Width="400" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="36*"/>
            <RowDefinition Height="145*"/>
        </Grid.RowDefinitions>
        <!-- Heading -->
        <TextBlock Text="Search Recipe" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30" Grid.RowSpan="3" Width="156"/>

        <!-- Enter Recipe Name Section -->
        <StackPanel HorizontalAlignment="Center" Margin="0,1,0,10" Grid.Row="2" Width="300">
            <TextBlock Text="Enter Recipe Name:" FontSize="18" Margin="0,0,0,5" HorizontalAlignment="Left"/>
            <TextBox x:Name="txtSearchRecipeName" Width="300" FontSize="16" Padding="8" Height="35"/>
        </StackPanel>

        <!-- Search Button -->
        <Button Content="Search" Width="100" FontSize="16" Background="#FFA000" Click="BtnSearch_Click" HorizontalAlignment="Center" Margin="0,73,0,21" Grid.Row="2"/>
    </Grid>
</Window>