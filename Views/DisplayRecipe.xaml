<Window x:Class="Prog6221PoeRecipeAppP3.Views.DisplayRecipe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Display Recipe" Height="600" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Recipe Name -->
        <TextBlock Grid.Row="0" x:Name="tbRecipeName" FontWeight="Bold" FontSize="28" TextDecorations="Underline"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10"/>

        <!-- Ingredients List -->
        <StackPanel Grid.Row="1" Margin="0,20,0,10">
            <TextBlock Text="Ingredients" FontWeight="Bold" FontSize="18"/>
            <DataGrid Grid.Row="1" x:Name="dgIngredients" AutoGenerateColumns="False" Margin="20,10,20,0" VerticalAlignment="Top" 
          HeadersVisibility="Column" ColumnWidth="*" BorderThickness="1"
          CanUserResizeColumns="True" CanUserReorderColumns="False"
          CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding Ingredients}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ingredient Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="*"/>
                    <DataGridTextColumn Header="Unit of Measurement" Binding="{Binding UnitOfMeasurement}" Width="*"/>
                    <DataGridTextColumn Header="Calories" Binding="{Binding Calories}" Width="*"/>
                    <DataGridTextColumn Header="Food Group" Binding="{Binding FoodGroup}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- Total Calories -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,10">
            <TextBlock FontWeight="Bold" FontSize="18" Text="Total Calories: " VerticalAlignment="Center"/>
            <TextBlock x:Name="tbTotalCalories" FontWeight="Bold" FontSize="18" Margin="5,0,10,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Calorie Warning Message -->
        <TextBlock Grid.Row="2" x:Name="tbCalorieWarning" FontSize="14" Foreground="Red"
                   Visibility="{Binding CalorieWarningVisibility}" Text="The total calories exceed 300!"
                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>

        <!-- Recipe Instructions -->
        <StackPanel Grid.Row="3" Margin="0,20,0,10">
            <TextBlock Text="Recipe Instructions" FontWeight="Bold" FontSize="18" Margin="0,10"/>
            <TextBox x:Name="tbRecipeInstructions" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     FontSize="16" Height="207" IsReadOnly="True"/>
        </StackPanel>

        <!-- Navigation Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
            <Button Content="Return to Main Window" FontSize="14" Margin="10"
                    Click="BtnReturnToMain_Click"/>
        </StackPanel>

        <!-- Divider -->
        <Rectangle Fill="Black" Height="2" Margin="0,57,20,88" Grid.RowSpan="2"/>
    </Grid>
</Window>
