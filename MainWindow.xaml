<Window x:Class="Prog6221PoeRecipeAppP3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <!-- Bold, underlined text at the top -->
            <TextBlock Text="Welcome to the Recipe App" FontWeight="Bold" FontSize="24" TextDecorations="Underline" Margin="0,0,0,20"/>

            <!-- Buttons with adjusted styles -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,20">
                <Button x:Name="btnAddRecipe" Content="Create a New Recipe" FontSize="16" Width="300" Height="50" Margin="0,0,0,10" Click="BtnAddRecipe_Click"/>
                <Button x:Name="btnDisplayRecipes" Content="Display Recipe List" FontSize="16" Width="300" Height="50" Margin="0,0,0,10" Click="BtnRecipeList_Click"/>
                <Button x:Name="btnSearchRecipe" Content="Search for a Recipe" FontSize="16" Width="300" Height="50" Margin="0,0,0,10" Click="BtnSearchRecipe_Click"/>
                <Button x:Name="btnExit" Content="Exit the Recipe App" FontSize="16" Width="300" Height="50" Click="BtnExit_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
